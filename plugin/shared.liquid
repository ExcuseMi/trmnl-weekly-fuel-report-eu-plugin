{% template block_identity %}
<div class="item flex--col no-shrink bg--white rounded overflow--hidden w--full md:portrait:hidden lg:portrait:hidden h--full">
  <img class="country-map image-dither h--[50cqh]" src="{{ data.map_url }}">
</div>
{% endtemplate %}

{% template block_electricity %}
<div class="item rounded bg--white p--3 w--full h--full">
  <div class="content w--full">
    <span class="value {% if view == 4 %}md:value--base lg:value--large{% elsif view == 3 %}value--xlarge md:value--large lg:value--xlarge{% elsif view == 2 %}md:value--large lg:value--xxxlarge{% else %}value--xlarge lg:value--xxxlarge{% endif %} text--center w--full">€{{ data.electricity | round: 2 | replace: ".", "," }}</span>
    <span class="label {% if view == 4 %}md:label--small lg:label--base{% elsif view == 3 %}label--large md:label--base lg:label--large{% elsif view == 2 %}md:label--base lg:label--xlarge{% else %}label--large lg:label--xlarge{% endif %}">Electricity /kWh</span>
    <div class="divider"></div>
    <div class="flex flex--row gap--sm mt--1 w--full flex--evenly">
      <div class="flex flex--col">
        <span class="value value--small lg:value--base {% if data.inflation > 0 %}text--error{% else %}text--success{% endif %}">{{ data.inflation | round: 1 | replace: ".", "," }}%</span>
        <span class="label label--small lg:label--base uppercase">Inflation</span>
      </div>
      <div class="divider--v"></div>
      <div class="flex flex--col">
        <span class="value value--small lg:value--base">{{ data.work_hours | round: 1 | replace: ".", "," }}h</span>
        <span class="label label--small lg:label--base uppercase">50L Labor</span>
      </div>
    </div>
  </div>
</div>
{% endtemplate %}

{% template block_fuel %}
<div class="item rounded bg--white  p--3 w--full h--full">
  <div class="content w--full">
    <div class="flex flex--row gap--sm align-items--center mb--1 w--full">
    </div>
    <span class="value {% if view == 4 %}md:value--base lg:value--large{% elsif view == 3 %}value--xlarge md:value--large lg:value--xlarge{% elsif view == 2 %}md:value--large lg:value--xxxlarge{% else %}value--xlarge lg:value--xxxlarge{% endif %} text--center w--full">€{{ value | round: 2 | replace: ".", "," }}</span>
    <span class="label {% if view == 4 %}md:label--small lg:label--base{% elsif view == 3 %}label--large md:label--base lg:label--large{% elsif view == 2 %}md:label--base lg:label--xlarge{% else %}label--large lg:label--xlarge{% endif %}">{{name}}</span>
    <div class="divider"></div>
    <div class="flex flex--row gap--sm mt--1 w--full flex--evenly">
      <div class="flex flex--col">
        <span class="value value--small lg:value--base {% if change > 0 %}text--error{% else %}text--success{% endif %}">
          {% if change > 0 %}▲{% else %}▼{% endif %} {{ change | abs | round: 2 | replace: ".", "," }}%
        </span>
        <span class="label label--small lg:label--base uppercase">WEEKLY</span>
      </div>
      <div class="divider--v {% if view == 3 or view == 4 %}md:hidden{% endif %}"></div>
      <div class="flex flex--col {% if view == 3 or view == 4 %}md:hidden{% endif %}">
        <span class="value value--small lg:value--base">{{ percent }}%</span>
        <span class="label label--small lg:label--base uppercase">VS EU AVG</span>
      </div>
    </div>
  </div>
</div>
{% endtemplate %}

{% template block_stats %}
<div class="grid w--full gap--small no-shrink {% if view == 2 or view == 3 or view == 4 %} md:hidden {% endif %}">
  <!-- Inflation -->
  <div class="col bg--white rounded p--3 text--center">
    <div class="flex flex--col align-items--center">

        <span class="label label--large label--underline">Inflation</span>
    </div>
    <div class="w--full mt--1">
      <span class="value lg:value--large">{{ data.inflation | round: 1 | replace: ".", "," }}%</span>
    </div>
  </div>

  <!-- Electricity -->
  <div class="col bg--white rounded p--3 text--center">
    <div class="flex flex--col align-items--center">
      <span class="label label--large label--underline">Electricity</span>
    </div>
    <div class="w--full mt--1">
      <span class="value value--small lg:value--large">€{{ data.electricity | round: 2 | replace: ".", "," }}</span>
      <br/><span class="label lg:label--large">/kWh</span>
    </div>
  </div>

  <!-- 50L Tank -->
  <div class="col bg--white rounded p--3 text--center portrait:hidden">
    <div class="flex flex--col align-items--center">
      <span class="label label--large label--underline">50L Tank</span>
    </div>
    <div class="w--full mt--1">
      {% if data.work_hours %}
      <span class="value value--small lg:value--large">{{ data.work_hours | round: 1 | replace: ".", "," }}h</span>
      <br/><span class="label lg:label--large">labor</span>
      {% else %}
      <span class="value value--small lg:value--large">€{{ data.tank_cost | round: 0 | replace: ".", "," }}</span>
      <br/><span class="label lg:label--large">cost</span>
      {% endif %}
    </div>
  </div>

  <div class="col col--span-2 bg--white rounded p--3 text--center portrait:hidden">
    {% render "block_trend" %}
  </div>
</div>
{% endtemplate %}

{% template block_trend %}
<div class="item no-shrink bg--white rounded p--2 w--full ">
  <div class="flex flex--col align-items--center w--full">

  <span class="label label--large lg:label--xxlarge label--underline block w--full text--center">
    8-Week Trend (E95)</span>
  <div id="fuel-chart" class="w--full" style="height: 100px;"></div>
</div>
  </div>

{% endtemplate %}

{% template dashboard %}
{% assign show_stats = true %}
{% if trmnl.plugin_settings.custom_fields_values.show_stats == "false" %}
  {% assign show_stats = false %}
{% endif %}

<div class="layout bg--gray-50 rounded">
  <div class="flex flex--col gap--small p--2 w--full h--full" data-overflow="true">

    <!-- Landscape: row of price blocks.
         First column (map/electricity) only on views 1+2 with stats enabled.
         Views 3+4 are compact — just the two price blocks. -->
    {% assign show_first_col = false %}
    {% if show_stats and view != 3 and view != 4 %}{% assign show_first_col = true %}{% endif %}

    <div class="columns portrait:hidden gap--small h--full">
      {% if show_first_col %}
        {% if view == 1 %}
        <div class="column col--span-2 h--full">
          {% render "block_identity", data: data, view: view %}
        </div>
        {% else %}
        <div class="column col--span-4 h--full">
          {% render "block_electricity", data: data, view: view %}
        </div>
        {% endif %}
      {% endif %}
      <div class="column {% if show_first_col %}col--span-4{% else %}col--span-5{% endif %} h--full">
        {% render "block_fuel", name: 'Petrol (E95)', value: data.petrol, change: data.petrol_change, percent: data.petrol_pct, view: view %}
      </div>
      <div class="column {% if show_first_col %}col--span-4{% else %}col--span-5{% endif %} h--full">
        {% render "block_fuel", name: 'Diesel', value: data.diesel, change: data.diesel_change, percent: data.diesel_pct, view: view %}
      </div>
    </div>

    <!-- Portrait: vertical stack, map only when stats are on -->
    <div class="hidden portrait:flex flex--col gap--small w--full no-shrink">
      {% if show_stats %}
        {% render "block_identity", data: data %}
      {% endif %}
      {% render "block_fuel", name: 'Petrol (E95)', value: data.petrol, change: data.petrol_change, percent: data.petrol_pct %}
      {% render "block_fuel", name: 'Diesel', value: data.diesel, change: data.diesel_change, percent: data.diesel_pct %}
    </div>

    <!-- Stats row (second row) -->
    {% if show_stats %}
      {% render "block_stats", data: data, view: view %}
    {% endif %}

  </div>
</div>

<script src="https://trmnl.com/js/highcharts/12.3.0/highcharts.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", function() {
    const trendData = {{ data.trend | json }};
  Highcharts.chart('fuel-chart', {
    chart: { type: 'area', animation: false, spacing: [2, 2, 2, 2], backgroundColor: 'transparent' },
    title: { text: null },
    credits: { enabled: false },
    legend: { enabled: false },
    xAxis: { visible: false },
    yAxis: { title: { text: null }, labels: { enabled: false }, gridLineWidth: 0 },
    plotOptions: {
      area: {
        animation: false,
        color: '#000',
        fillOpacity: 0.1,
        lineWidth: 2,
        marker: { enabled: true, radius: 2, fillColor: '#000' }
      }
    },
    series: [{ data: trendData }]
  });
  });
</script>

{% unless trmnl.plugin_settings.custom_fields_values.hide_title_bar == 'yes' %}
<div class="title_bar">
  {% render "icon_fuel", class: "w--8 image-stroke" %}
  <h1 class="title text-stroke">Weekly Fuel Report</h1>
  <span class="instance">{{ data.name }} · {{ data.last_updated | date: "%b %d" }}</span>
</div>
{% endunless %}
{% endtemplate %}
