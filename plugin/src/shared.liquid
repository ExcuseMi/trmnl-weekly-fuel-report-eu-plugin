{% template dashboard %}
<style>
  .country-flag { width: 100px; border: 1px solid #000; }
  .text--bold { font-weight: bold; }
  .chart-container { height: 90px; width: 100%; }
  .label--tiny { font-size: 0.6em; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.8; }
</style>

<div class="layout layout--col gap--medium">
  <!-- Top Section: 3-Column Grid (Flag | Petrol Insights | Diesel Insights) -->
  <div class="grid">
    <!-- Country Flag -->
    <div class="row row--center col--span-3 col--end">
      <img class="country-flag image-dither" src="https://flagcdn.com/{{ data.code | downcase }}.svg">
    </div>

    <!-- Petrol Insights Block -->
    <div class="col col--span-3 col--end">
      <div class="item h--full bg--gray-75 rounded--small p--3">
        <div class="content">
          <span class="value value--xxlarge">€{{ data.petrol | number_with_precision: 3 }}</span>
          <span class="label">Petrol (E95)</span>
          
          <div class="flex flex--row gap--md mt--2">
            <div class="flex flex--col">
              <span class="value value--xxsmall {% if data.petrol_change > 0 %}text--error{% else %}text--success{% endif %}">
                {% if data.petrol_change > 0 %}▲{% else %}▼{% endif %} {{ data.petrol_change | abs }}%
              </span>
              <span class="label label--tiny">Weekly</span>
            </div>
            <div class="flex flex--col">
              <span class="value value--xxsmall">{{ data.petrol_pct }}%</span>
              <span class="label label--tiny">vs EU Avg</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Diesel Insights Block -->
    <div class="col col--span-3 col--end">
      <div class="item h--full bg--gray-75 rounded--small p--3">
        <div class="content">
          <span class="value value--xxlarge">€{{ data.diesel | number_with_precision: 3 }}</span>
          <span class="label">Diesel</span>
          
          <div class="flex flex--row gap--md mt--2">
            <div class="flex flex--col">
              <span class="value value--xxsmall {% if data.diesel_change > 0 %}text--error{% else %}text--success{% endif %}">
                {% if data.diesel_change > 0 %}▲{% else %}▼{% endif %} {{ data.diesel_change | abs }}%
              </span>
              <span class="label label--tiny">Weekly</span>
            </div>
            <div class="flex flex--col">
              <span class="value value--xxsmall">{{ data.diesel_pct }}%</span>
              <span class="label label--tiny">vs EU Avg</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Section: 5-Column Grid -->
  <div class="grid grid--cols-5 gap--small">
    <div class="col col--start gap--medium text--center bg--gray-75 rounded--small p--3">
      <span class="title text--bold">Inflation</span>
      <div class="w--full mt--1">
        <span class="value value--small">{{ data.inflation }}%</span>
      </div>
    </div>

    <div class="col col--start gap--medium text--center bg--gray-75 rounded--small p--3">
      <span class="title text--bold">Electricity</span>
      <div class="w--full mt--1">
        <span class="value value--small">€{{ data.electricity | number_with_precision: 2 }}</span>
        <br/><span class="label small">/kWh</span>
      </div>
    </div>

    <div class="col col--start gap--medium text--center bg--gray-75 rounded--small p--3">
      <span class="title text--bold">50L Tank</span>
      <div class="w--full mt--1">
        <span class="value value--small">{{ data.work_hours }}h</span>
        <br/><span class="label small">labor</span>
      </div>
    </div>

    <!-- Chart Card spanning 2 columns -->
    <div class="col col--span-2 col--start gap--medium bg--gray-75 rounded--small p--2">
      <span class="title text--bold text--center w--full">8-Week Trend (E95)</span>
      <div id="fuel-chart" class="w--full grow chart-container"></div>
    </div>
  </div>
</div>

<script src="https://trmnl.com/js/highcharts/12.3.0/highcharts.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", function() {
    const trendData = {{ data.trend | json }};
    Highcharts.chart('fuel-chart', {
      chart: { type: 'area', animation: false, spacing: [2, 2, 2, 2], backgroundColor: 'transparent' },
      title: { text: null },
      credits: { enabled: false },
      legend: { enabled: false },
      xAxis: { visible: false },
      yAxis: { title: { text: null }, labels: { enabled: false }, gridLineWidth: 0 },
      plotOptions: {
        area: {
          animation: false,
          color: '#000',
          fillOpacity: 0.1,
          lineWidth: 2,
          marker: { enabled: true, radius: 2, fillColor: '#000' }
        }
      },
      series: [{ data: trendData }]
    });
  });
</script>

{% unless trmnl.plugin_settings.custom_fields_values.hide_title_bar == 'yes' %}
<div class="title_bar">
  <svg class="image" fill="#000000" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
    <path d="M19 12V7.5C19 6.12 17.88 5 16.5 5S14 6.12 14 7.5V13c0 .55-.45 1-1 1s-1-.45-1-1V7c0-2.21-1.79-4-4-4S4 4.79 4 7v14h10v-2h1v2c0 .55.45 1 1 1s1-.45 1-1v-2h1c1.1 0 2-.9 2-2V12h-1zM8 18c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zM12 9H6V7h6v2z"/>
  </svg>
  <h1 class="title">Weekly Fuel Report (EU)</h1>
  <span class="instance">{{ data.name }} · {{ data.last_updated | date: "%b %d" }}</span>
</div>
{% endunless %}
{% endtemplate %}
