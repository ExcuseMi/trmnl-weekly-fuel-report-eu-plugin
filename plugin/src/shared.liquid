{% template fuel %}
<div class="item h--full bg--white rounded p--3">
  <div class="content w--full ">
    <span class="value value--xlarge lg:value--xxxlarge">€{{ value | number_with_precision: 3 | replace: ".", "," }}</span>
    <span class="label lg:label--xlarge">{{name}}</span>
    <div class="divider"></div>

    <div class="flex flex--row gap--md mt--2 w--full flex--evenly">
      <div class="flex flex--col ">
        <span class="value value--small lg:value--base {% if change > 0 %}text--error{% else %}text--success{% endif %}">
          {% if change > 0 %}▲{% else %}▼{% endif %} {{ change | abs | number_with_precision: 2 | replace: ".", "," }}%
        </span>
        <span class="label label--small  lg:label--base">WEEKLY</span>
      </div>
      <div class="divider--v"></div>

      <div class="flex flex--col">
        <span class="value value--small lg:value--base">{{ percent }}%</span>
        <span class="label label--small lg:label--base">VS EU AVG</span>
      </div>
    </div>
  </div>
</div>

{% endtemplate %}
{% template dashboard %}

<style>
  .text--bold { font-weight: bold; }
  .identity-wrapper { height: 120px; position: relative; padding: 10px; display: flex; align-items: center; justify-content: center; }
  .flag-pole { width: 4px; height: 80px; background: #000; border-radius: 2px; position: absolute; left: 20px; bottom: 20px; z-index: 5; }
  .flag-img { height: 45px; border: 1px solid #000; object-fit: contain; position: absolute; left: 24px; bottom: 55px; z-index: 6; }
  .country-map { height: 100px; object-fit: contain; opacity: 0.2; position: absolute; right: 10px; bottom: 10px; z-index: 1; }
</style>

<div class="layout layout--col gap--medium bg--gray-65 p--2">
  <!-- Top Section: 3-Column Grid -->
  <div class="grid stretch">
    <!-- Country Identity (Flag + Map) -->
    <div class="row row--center col--span-3 col--end bg--white rounded overflow--hidden">
      <div class="flex flex--col w--full h--full">
        <div class="value value--large bg--black text--white w--full p--1" data-value-fit="true">{{data.name }}</div>
        <div class="identity-wrapper grow">
          <div class="flag-pole"></div>
          <img class="flag-img image-dither" src="{{ data.flag_url }}">
          <img class="country-map image-dither" src="{{ data.map_url }}">
        </div>
      </div>
    </div>

    <!-- Petrol Insights Block -->
    <div class="col col--span-3 col--end">
      {% render "fuel", name: 'Petrol (E95)', value: data.petrol, change: data.petrol_change, percent: data.petrol_pct %}
    </div>

    <!-- Diesel Insights Block -->
    <div class="col col--span-3 col--end">
      {% render "fuel", name: 'Diesel', value: data.diesel, change: data.diesel_change, percent: data.diesel_pct %}
    </div>
  </div>

  <!-- Bottom Section: 5-Column Grid -->
  <div class="grid grid--cols-5 gap--small  h--[30cqh]">
    <div class="col col--start gap--medium text--center bg--white rounded p--3">
      <span class="label label--large lg:label--xxlarge label--underline">Inflation</span>
      <div class="w--full mt--1">
        <span class="value lg:value--large">{{ data.inflation | number_with_precision: 1 | replace: ".", "," }}%</span>
      </div>
    </div>

    <div class="col col--start gap--medium text--center bg--white rounded p--3">
      <span class="label label--large lg:label--xxlarge label--underline">Electricity</span>
      <div class="w--full mt--1">
        <span class="value value--small lg:value--large">€{{ data.electricity | number_with_precision: 2 | replace: ".", "," }}</span>
        <br/><span class="label lg:label--large">/kWh</span>
      </div>
    </div>

    <div class="col col--start gap--medium text--center bg--white rounded p--3">
      <span class="label label--large lg:label--xxlarge label--underline">50L Tank</span>
      <div class="w--full mt--1">
        <span class="value value--small lg:value--large">{{ data.work_hours | number_with_precision: 1 | replace: ".", "," }}h</span>
        <br/><span class="label lg:label--large">labor</span>
      </div>
    </div>

    <!-- Chart Card spanning 2 columns -->
    <div class="col col--span-2 col--start gap--medium bg--white rounded p--2">
      <span class="label label--large lg:label--xxlarge label--underline">8-Week Trend (E95)</span>
      <div id="fuel-chart" class="w--full  h--full grow chart-container"></div>
    </div>
  </div>
</div>

<script src="https://trmnl.com/js/highcharts/12.3.0/highcharts.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", function() {
    const trendData = {{ data.trend | json }};
  Highcharts.chart('fuel-chart', {
    chart: { type: 'area', animation: false, spacing: [2, 2, 2, 2], backgroundColor: 'transparent' },
    title: { text: null },
    credits: { enabled: false },
    legend: { enabled: false },
    xAxis: { visible: false },
    yAxis: { title: { text: null }, labels: { enabled: false }, gridLineWidth: 0 },
    plotOptions: {
      area: {
        animation: false,
        color: '#000',
        fillOpacity: 0.1,
        lineWidth: 2,
        marker: { enabled: true, radius: 2, fillColor: '#000' }
      }
    },
    series: [{ data: trendData }]
  });
  });
</script>

{% unless trmnl.plugin_settings.custom_fields_values.hide_title_bar == 'yes' %}
<div class="title_bar">
  {% render "icon", class:"w--8 image-stroke" %}
  <h1 class="title text-stroke">Weekly Fuel Report</h1>
  <span class="instance">{{ data.name }} · {{ data.last_updated | date: "%b %d" }}</span>
</div>
{% endunless %}
{% endtemplate %}
